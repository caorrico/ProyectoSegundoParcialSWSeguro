# =============================================================================
# ProyectoSegundoParcialSWSeguro — .gitignore
# Python | ML/AI | Node.js | Java | IDEs | OS
# =============================================================================

# ─── Python ──────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
*.pyd

# Distribution / packaging
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# Virtual environments
.venv/
venv/
env/
ENV/
env.bak/
venv.bak/
__pypackages__/

# Unit tests / coverage
htmlcov/
.tox/
.nox/
.coverage
.coverage.*
.cache
nosetests.xml
coverage.xml
*.cover
*.py,cover
.pytest_cache/
pytestdebug.log

# Type checkers
.mypy_cache/
.dmypy.json
dmypy.json
.pyre/
.pytype/
cython_debug/

# Misc Python tools
.spyderproject
.spyproject
.ropeproject
.pybuilder/
profile_default/
ipython_config.py
.ipynb_checkpoints
celerybeat-schedule
celerybeat.pid
*.sage.py

# ─── Machine Learning Models (large binary files) ────────────────────────────
models/*.joblib
models/*.pkl
models/*.h5
models/*.onnx
models/*.bin
models/*.pt
models/*.pth
models/*.safetensors

# Keep directory tracked
!models/.gitkeep

# ─── Datasets (large / proprietary) ─────────────────────────────────────────
# Real-world vulnerability datasets — download separately via scripts
data/codexglue/
data/d2a/
data/reveal/
data/megavul/
megavul/
data/raw/*
!data/raw/.gitkeep
data/processed/
data/vulberta/
data/finetune/

# Generated OWASP 2025 dataset (can be regenerated with scripts/generate_owasp_dataset.py)
data/owasp2025/

# CVEFixes DB (download separately)
data/cvefixes/
*.db
*.sqlite3
*.sqlite3-journal

# Keep directory markers
!data/.gitkeep
!data/owasp2025/.gitkeep
!data/processed/.gitkeep

# ─── Reports & scan outputs ──────────────────────────────────────────────────
reports/
examples/**/*.json
examples/**/*.html
examples/**/*.png
examples/**/vulnerability_scan_report.json
examples/**/reports/

# ─── Logs ────────────────────────────────────────────────────────────────────
*.log
pip-log.txt
pip-delete-this-directory.txt
local_settings.py

# ─── Secrets / Credentials ────────────────────────────────────────────────────
.env
.env.*
!.env.example
secrets.yaml
credentials.json
*.pem
*.key
*.p12
*.pfx

# ─── Node.js / TypeScript ────────────────────────────────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.npm
.yarn/
dist/
.next/
.nuxt/
.output/
.turbo/
*.tsbuildinfo

# ─── Java / Maven / Gradle ───────────────────────────────────────────────────
target/
*.class
*.jar
*.war
*.ear
.gradle/
build/
gradle-wrapper.jar
hs_err_pid*

# ─── IDEs ────────────────────────────────────────────────────────────────────
# JetBrains (IntelliJ, PyCharm, etc.)
.idea/
*.iws
*.iml
*.ipr
out/

# VS Code
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
*.code-workspace

# Eclipse
.classpath
.project
.settings/
.factorypath

# ─── OS specific ─────────────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# ─── Temp / Debug scripts ────────────────────────────────────────────────────
test_cwd.py
test_import.py
test_python.py
test_run.py
scratch_*.py
debug_*.py

# ─── GitHub Actions cache ────────────────────────────────────────────────────
.github/workflows/*.cache

# ─── Sphinx docs ─────────────────────────────────────────────────────────────
docs/_build/
/site
